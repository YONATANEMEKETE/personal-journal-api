@baseUrl = http://localhost:3000

### Health check
GET {{baseUrl}}/health

### Register — success
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Alice",
  "email": "alice@example.com",
  "password": "password123"
}

### Register — missing name
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "bob@example.com",
  "password": "password123"
}

### Register — invalid email
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Bob",
  "email": "not-an-email",
  "password": "password123"
}

### Register — short password
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Bob",
  "email": "bob@example.com",
  "password": "123"
}

### Register — duplicate email (run after the success case)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Alice Clone",
  "email": "alice@example.com",
  "password": "password123"
}

### Register — empty body
POST {{baseUrl}}/auth/register
Content-Type: application/json

{}

### Register — email with mixed casing (should be lowercased)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Charlie",
  "email": "Charlie@Example.com",
  "password": "securePass1"
}

### NOTE: Login — success (use Alice credentials)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "password123"
}

### Login — wrong password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "wrongpassword"
}

### Login — non-existent email
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "nobody@example.com",
  "password": "password123"
}

### Login — missing password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com"
}

### Login — invalid email format
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "not-an-email",
  "password": "password123"
}

### Login — empty body
POST {{baseUrl}}/auth/login
Content-Type: application/json

{}

### Me — success (run login success first to establish session)
GET {{baseUrl}}/auth/me

### Me — unauthenticated (no session cookie)
GET {{baseUrl}}/auth/me

### Logout — success (run login success first to establish session)
POST {{baseUrl}}/auth/logout

### Logout — unauthenticated (no session cookie, or after logout clears it)
POST {{baseUrl}}/auth/logout

### Create Entry — success (run login first to establish session)
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "title": "My First Entry",
  "content": "Today was a great day. I learned a lot about backend development.",
  "entryDate": "2026-06-08"
}

### Create Entry — duplicate title (run after the success case)
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "title": "My First Entry",
  "content": "This should conflict.",
  "entryDate": "2026-06-08"
}

### Create Entry — missing title
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "content": "Some content",
  "entryDate": "2026-06-08"
}

### Create Entry — invalid entryDate format
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "title": "Test",
  "content": "Content here",
  "entryDate": "not-a-date"
}

### Create Entry — with tags (run login + create tags first)
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "title": "Entry With Tags",
  "content": "This entry has mood tags attached.",
  "entryDate": "2026-06-08",
  "tagIds": ["replace-with-actual-tag-uuid"]
}

### Create Entry — unauthenticated (no session cookie)
POST {{baseUrl}}/entries
Content-Type: application/json

{
  "title": "Should Not Create",
  "content": "This should fail with 401.",
  "entryDate": "2026-06-08"
}

### Get Entry — success (replace with actual entry ID)
GET {{baseUrl}}/entries/replace-with-actual-entry-uuid

### Get Entry — not found (valid UUID but no entry)
GET {{baseUrl}}/entries/00000000-0000-0000-0000-000000000000

### Get Entry — invalid entryId format (not a UUID)
GET {{baseUrl}}/entries/not-a-uuid

### NOTE: Update Entry — success (replace with actual entry ID)
PATCH {{baseUrl}}/entries/replace-with-actual-entry-uuid
Content-Type: application/json

{
  "title": "Updated Title",
  "content": "Updated content."
}

### Update Entry — empty title
PATCH {{baseUrl}}/entries/replace-with-actual-entry-uuid
Content-Type: application/json

{
  "title": ""
}

### Update Entry — not found
PATCH {{baseUrl}}/entries/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "title": "Ghost Entry"
}

### NOTE: Delete Entry — success (run after creating an entry, replace UUID)
DELETE {{baseUrl}}/entries/replace-with-actual-entry-uuid

### Delete Entry — not found (valid UUID, no entry)
DELETE {{baseUrl}}/entries/00000000-0000-0000-0000-000000000000

### Delete Entry — invalid entryId format (not a UUID)
DELETE {{baseUrl}}/entries/not-a-uuid

### Delete Entry — unauthenticated (no session cookie)
DELETE {{baseUrl}}/entries/00000000-0000-0000-0000-000000000001

### NOTE: List Entries — success (basic, no filters)
GET {{baseUrl}}/entries

### List Entries — with pagination
GET {{baseUrl}}/entries?page=1&limit=10

### List Entries — with date range
GET {{baseUrl}}/entries?dateFrom=2026-06-01&dateTo=2026-06-30

### List Entries — with search
GET {{baseUrl}}/entries?search=great

### List Entries — sorted ascending by title
GET {{baseUrl}}/entries?sortBy=title&sortDir=asc

### List Entries — with tagIds filter
GET {{baseUrl}}/entries?tagIds=replace-with-actual-tag-uuid

### List Entries — unauthenticated (no session cookie)
GET {{baseUrl}}/entries

### List Entries — invalid sortBy value
GET {{baseUrl}}/entries?sortBy=invalidColumn

### List Entries — limit exceeds max (should clamp to 100)
GET {{baseUrl}}/entries?limit=999

### Create Tag — success (run login first to establish session)
POST {{baseUrl}}/tags
Content-Type: application/json

{
  "name": "grateful",
  "color": "AMBER"
}

### Create Tag — default color (without color field)
POST {{baseUrl}}/tags
Content-Type: application/json

{
  "name": "productive"
}

### Create Tag — duplicate name (run after the success case)
POST {{baseUrl}}/tags
Content-Type: application/json

{
  "name": "grateful"
}

### Create Tag — missing name
POST {{baseUrl}}/tags
Content-Type: application/json

{}

### Create Tag — invalid color enum value
POST {{baseUrl}}/tags
Content-Type: application/json

{
  "name": "test",
  "color": "INVALID_COLOR"
}

### Create Tag — unauthenticated (no session cookie)
POST {{baseUrl}}/tags
Content-Type: application/json

{
  "name": "should-fail"
}

### List Tags — success (run login first)
GET {{baseUrl}}/tags

### List Tags — with entry count
GET {{baseUrl}}/tags?includeEntryCount=true

### List Tags — unauthenticated (no session cookie)
GET {{baseUrl}}/tags

### Get Tag — success (replace with actual tag UUID, run login first)
GET {{baseUrl}}/tags/replace-with-actual-tag-uuid

### Get Tag — not found (valid UUID, no tag)
GET {{baseUrl}}/tags/00000000-0000-0000-0000-000000000000

### Get Tag — invalid tagId format (not a UUID)
GET {{baseUrl}}/tags/not-a-uuid

### Get Tag — unauthenticated (no session cookie)
GET {{baseUrl}}/tags/00000000-0000-0000-0000-000000000000

### Update Tag — success (replace with actual tag UUID, run login first)
PATCH {{baseUrl}}/tags/replace-with-actual-tag-uuid
Content-Type: application/json

{
  "name": "updated-tag-name",
  "color": "BLUE"
}

### Update Tag — update name only
PATCH {{baseUrl}}/tags/replace-with-actual-tag-uuid
Content-Type: application/json

{
  "name": "renamed-tag"
}

### Update Tag — not found (valid UUID, no tag)
PATCH {{baseUrl}}/tags/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "name": "ghost-tag"
}

### Update Tag — empty name
PATCH {{baseUrl}}/tags/replace-with-actual-tag-uuid
Content-Type: application/json

{
  "name": ""
}

### Update Tag — invalid color enum
PATCH {{baseUrl}}/tags/replace-with-actual-tag-uuid
Content-Type: application/json

{
  "color": "INVALID"
}

### Delete Tag — success (replace with actual tag UUID, run login first)
DELETE {{baseUrl}}/tags/replace-with-actual-tag-uuid

### Delete Tag — not found (valid UUID, no tag)
DELETE {{baseUrl}}/tags/00000000-0000-0000-0000-000000000000

### Delete Tag — invalid tagId format (not a UUID)
DELETE {{baseUrl}}/tags/not-a-uuid

### Delete Tag — unauthenticated (no session cookie)
DELETE {{baseUrl}}/tags/00000000-0000-0000-0000-000000000000

### Assign Tags to Entry — success (replace with actual entry UUID and tag UUIDs, run login first)
POST {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags
Content-Type: application/json

{
  "tagIds": ["replace-with-actual-tag-uuid-1", "replace-with-actual-tag-uuid-2"]
}

### Assign Tags — entry not found
POST {{baseUrl}}/entries/00000000-0000-0000-0000-000000000000/tags
Content-Type: application/json

{
  "tagIds": ["00000000-0000-0000-0000-000000000000"]
}

### Assign Tags — missing tagIds field
POST {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags
Content-Type: application/json

{}

### Assign Tags — empty tagIds array
POST {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags
Content-Type: application/json

{
  "tagIds": []
}

### Assign Tags — invalid UUID in tagIds
POST {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags
Content-Type: application/json

{
  "tagIds": ["not-a-uuid"]
}

### Remove Tag from Entry — success (replace with actual entry UUID and tag UUID)
DELETE {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags/replace-with-actual-tag-uuid

### Remove Tag — entry not found
DELETE {{baseUrl}}/entries/00000000-0000-0000-0000-000000000000/tags/00000000-0000-0000-0000-000000000000

### Remove Tag — tag not found (valid UUIDs but no relationship)
DELETE {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags/00000000-0000-0000-0000-000000000000

### Remove Tag — invalid entryId format
DELETE {{baseUrl}}/entries/not-a-uuid/tags/00000000-0000-0000-0000-000000000000

### Remove Tag — invalid tagId format
DELETE {{baseUrl}}/entries/replace-with-actual-entry-uuid/tags/not-a-uuid